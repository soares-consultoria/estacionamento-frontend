# URL base do backend (sem barra no final)
#
# Desenvolvimento local — aponta direto para o backend na porta 8181:
VITE_API_URL=http://localhost:8181/estacionamento-api
#
# Produção (EC2 com Nginx proxy reverso configurado via nginx.conf):
# Deixar vazio para usar mesma origem (Nginx faz o proxy /estacionamento-api/ → :8181)
# VITE_API_URL=
#
# Produção sem proxy (acesso direto à porta 8181):
# VITE_API_URL=http://ec2-16-58-227-174.us-east-2.compute.amazonaws.com:8181/estacionamento-api
